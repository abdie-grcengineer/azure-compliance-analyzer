# Copy to terraform.tfvars and fill in.

resource_group_name = "rg-aca"
location            = "eastus"
project_name        = "aca"
environment         = "demo"

# Defender's built-in NIST SP 800-171 Rev. 2 standard is the underlying
# control set CMMC Level 2 enforces. Swap to a different built-in or a
# custom standard if your tenant uses one.
defender_standard_name = "NIST SP 800-171 Rev. 2"

foundry_model_name     = "Phi-4"
foundry_model_version  = "3"
foundry_model_format   = "Microsoft"
foundry_model_capacity = 1
