{
  "framework": "CMMC L2",
  "version": "v1",
  "underlying_standard": "NIST SP 800-171 Rev. 2",
  "notes": "Keyword-based starter mapping for CMMC Level 2 practices. Each keyword match suggests one or more CMMC practice IDs in the form DOMAIN.L2-3.x.x. Replace with org-curated mapping for production assessments.",
  "domains": {
    "AC": "Access Control",
    "AT": "Awareness and Training",
    "AU": "Audit and Accountability",
    "CM": "Configuration Management",
    "IA": "Identification and Authentication",
    "IR": "Incident Response",
    "MA": "Maintenance",
    "MP": "Media Protection",
    "PE": "Physical Protection",
    "PS": "Personnel Security",
    "RA": "Risk Assessment",
    "CA": "Security Assessment",
    "SC": "System and Communications Protection",
    "SI": "System and Information Integrity"
  },
  "keywords": [
    {
      "match": ["encrypt at rest", "encryption at rest", "kms", "key vault", "customer-managed key", "cmk"],
      "practices": ["SC.L2-3.13.11", "SC.L2-3.13.16"]
    },
    {
      "match": ["encrypt in transit", "tls", "ssl", "https only"],
      "practices": ["SC.L2-3.13.8"]
    },
    {
      "match": ["public", "internet exposed", "anonymous access", "publicly accessible"],
      "practices": ["AC.L2-3.1.3", "SC.L2-3.13.1", "SC.L2-3.13.5"]
    },
    {
      "match": ["log", "audit log", "diagnostic", "activity log"],
      "practices": ["AU.L2-3.3.1", "AU.L2-3.3.2"]
    },
    {
      "match": ["log retention", "log review", "audit review"],
      "practices": ["AU.L2-3.3.3", "AU.L2-3.3.5"]
    },
    {
      "match": ["mfa", "multi-factor", "multifactor", "two-factor"],
      "practices": ["IA.L2-3.5.3"]
    },
    {
      "match": ["password", "credential", "secret"],
      "practices": ["IA.L2-3.5.7", "IA.L2-3.5.10"]
    },
    {
      "match": ["backup", "recovery", "restore"],
      "practices": ["MP.L2-3.8.9"]
    },
    {
      "match": ["patch", "update", "vulnerability scan", "vulnerability assessment"],
      "practices": ["RA.L2-3.11.2", "SI.L2-3.14.1"]
    },
    {
      "match": ["network", "firewall", "nsg", "security group", "subnet"],
      "practices": ["SC.L2-3.13.1", "SC.L2-3.13.5", "AC.L2-3.1.3"]
    },
    {
      "match": ["role", "rbac", "permission", "least privilege"],
      "practices": ["AC.L2-3.1.5"]
    },
    {
      "match": ["session", "remote access", "vpn", "jump"],
      "practices": ["AC.L2-3.1.12", "AC.L2-3.1.13"]
    },
    {
      "match": ["malware", "antivirus", "endpoint protection", "defender"],
      "practices": ["SI.L2-3.14.2", "SI.L2-3.14.4", "SI.L2-3.14.5"]
    },
    {
      "match": ["incident", "alert", "siem"],
      "practices": ["IR.L2-3.6.1", "IR.L2-3.6.2"]
    },
    {
      "match": ["configuration", "baseline", "drift", "hardening"],
      "practices": ["CM.L2-3.4.1", "CM.L2-3.4.2"]
    },
    {
      "match": ["just-in-time", "jit", "privileged access"],
      "practices": ["AC.L2-3.1.2", "AC.L2-3.1.5"]
    }
  ]
}
